<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AgentShare Node</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: #050510; color: #e0e0ff;
      height: 100vh; overflow: hidden; display: flex; flex-direction: column;
    }
    .header {
      padding: 16px 24px; border-bottom: 1px solid #1a1a3a;
      display: flex; align-items: center; gap: 10px;
      background: #080818; flex-shrink: 0;
    }
    .header-logo {
      font-size: 20px; font-weight: 700;
      background: linear-gradient(135deg, #9945ff, #14f195);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    }
    .header-version { font-size: 11px; color: #5555aa; margin-left: auto; }
    .main {
      flex: 1; overflow-y: auto; padding: 20px 24px;
      display: flex; flex-direction: column; gap: 16px;
    }
    .main::-webkit-scrollbar { width: 4px; }
    .main::-webkit-scrollbar-track { background: transparent; }
    .main::-webkit-scrollbar-thumb { background: #2a2a6a; border-radius: 2px; }
    .card { background: #0a0a20; border: 1px solid #1a1a3a; border-radius: 12px; padding: 18px 20px; }
    .card-title {
      font-size: 12px; font-weight: 600; text-transform: uppercase;
      letter-spacing: 0.08em; color: #5555aa; margin-bottom: 14px;
      display: flex; align-items: center; justify-content: space-between;
    }
    .status-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    .status-item { background: #0d0d28; border: 1px solid #1e1e48; border-radius: 8px; padding: 12px 14px; }
    .status-item label { display: block; font-size: 10px; color: #5555aa; margin-bottom: 4px; text-transform: uppercase; letter-spacing: 0.05em; }
    .status-item .value { font-size: 14px; font-weight: 600; color: #c8c8ff; display: flex; align-items: center; gap: 6px; }
    .dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
    .dot.connected { background: #14f195; box-shadow: 0 0 6px #14f19566; }
    .dot.disconnected { background: #ff4466; }
    .highlight-green { color: #14f195; }
    .highlight-purple { color: #9945ff; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 10px; }
    .form-group { display: flex; flex-direction: column; gap: 5px; }
    .form-group.full { grid-column: 1 / -1; }
    .form-group label { font-size: 11px; color: #7777bb; }
    .form-group input, .form-group select {
      background: #0d0d28; border: 1px solid #2a2a5a; border-radius: 6px;
      padding: 8px 10px; color: #e0e0ff; font-size: 13px; outline: none; transition: border-color 0.2s;
    }
    .form-group input:focus, .form-group select:focus { border-color: #9945ff; }
    .form-group select option { background: #0d0d28; }
    .toggle-btn { width: 100%; padding: 10px; border-radius: 8px; border: none; font-size: 14px; font-weight: 600; cursor: pointer; margin-top: 4px; transition: all 0.2s; }
    .toggle-btn.start { background: linear-gradient(135deg, #9945ff, #6633cc); color: #fff; }
    .toggle-btn.start:hover { opacity: 0.9; }
    .toggle-btn.stop { background: #1a1a3a; border: 1px solid #ff4466; color: #ff4466; }
    .toggle-btn.stop:hover { background: #2a0a1a; }
    .toggle-btn:disabled { opacity: 0.4; cursor: not-allowed; }
    .earnings-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 14px; }
    .earnings-item { background: #0d0d28; border: 1px solid #1e1e48; border-radius: 8px; padding: 12px 14px; text-align: center; }
    .earnings-item .big { font-size: 22px; font-weight: 700; }
    .earnings-item .label { font-size: 10px; color: #5555aa; margin-top: 2px; text-transform: uppercase; }
    .tx-list { display: flex; flex-direction: column; gap: 6px; }
    .tx-item { display: flex; justify-content: space-between; align-items: center; background: #0d0d28; border: 1px solid #1a1a3a; border-radius: 6px; padding: 8px 12px; font-size: 12px; }
    .tx-item .tx-type { color: #9945ff; font-weight: 600; }
    .tx-item .tx-sol { color: #14f195; font-weight: 600; }
    .tx-item .tx-time { color: #5555aa; font-size: 11px; }
    .tx-empty { color: #5555aa; font-size: 12px; text-align: center; padding: 10px; }
    .status-msg { font-size: 11px; color: #5555aa; text-align: center; padding: 4px 0; min-height: 18px; }
    .status-msg.ok { color: #14f195; }
    .status-msg.err { color: #ff4466; }

    /* === AGENT PANEL === */
    .agent-panel { position: relative; overflow: visible; }
    .agent-level-badge { background: linear-gradient(135deg,#9945ff,#14f195); -webkit-background-clip:text; -webkit-text-fill-color:transparent; font-size:14px; font-weight:800; text-transform:none; letter-spacing:0; }
    .agent-main { display: flex; gap: 16px; margin-bottom: 10px; }
    .agent-avatar-wrap { position:relative; cursor:pointer; flex-shrink:0; width:72px; height:72px; display:flex; align-items:center; justify-content:center; background:#0d0d28; border:1px solid #2a2a5a; border-radius:12px; transition:border-color 0.2s; user-select:none; }
    .agent-avatar-wrap:hover { border-color:#9945ff66; }
    .agent-avatar-wrap:active { transform:scale(0.95); }
    #agent-avatar { font-size:40px; line-height:1; transition:all 0.3s; display:block; }
    #agent-avatar.turned { transform:scaleX(-1); filter:grayscale(0.4); }
    #agent-avatar.fainted { transform:rotate(90deg); filter:grayscale(1); }
    .zzz-container { position:absolute; top:-8px; right:-8px; pointer-events:none; overflow:visible; }
    .zzz-letter { position:absolute; font-size:12px; font-weight:700; color:#9945ff; opacity:0; animation:zzz-rise 2.4s ease-in-out infinite; }
    .zzz-letter:nth-child(1) { left:0;    top:0;   animation-delay:0s;   font-size:10px; }
    .zzz-letter:nth-child(2) { left:8px;  top:-4px; animation-delay:0.7s; font-size:13px; }
    .zzz-letter:nth-child(3) { left:18px; top:-8px; animation-delay:1.4s; font-size:17px; }
    @keyframes zzz-rise { 0%{opacity:0;transform:translate(0,0) rotate(-10deg)} 20%{opacity:1} 80%{opacity:0.6} 100%{opacity:0;transform:translate(-6px,-28px) rotate(12deg)} }
    .agent-right { flex:1; display:flex; flex-direction:column; gap:7px; min-width:0; }
    .speech-bubble { background:#0d0d28; border:1px solid #2a2a5a; border-radius:10px; border-bottom-left-radius:2px; padding:8px 12px; font-size:12px; color:#c8c8ff; line-height:1.45; min-height:38px; word-break:break-word; }
    .stat-row { display:flex; align-items:center; gap:8px; }
    .stat-label { font-size:10px; color:#5555aa; width:34px; flex-shrink:0; }
    .bar-track { flex:1; height:6px; background:#1a1a3a; border-radius:3px; overflow:hidden; }
    .bar-fill { height:100%; border-radius:3px; transition:width 0.5s ease; }
    .exp-fill    { background:linear-gradient(90deg,#9945ff,#cc77ff); }
    .hunger-fill { background:linear-gradient(90deg,#ff6600,#ffaa00); }
    .happy-fill  { background:linear-gradient(90deg,#14f195,#00ccff); }
    .stat-val { font-size:10px; color:#7777bb; width:30px; text-align:right; flex-shrink:0; }
    .agent-action-row { display:flex; gap:8px; margin-top:2px; }
    .feed-btn { background:#1a1a3a; border:1px solid #ff6600; border-radius:6px; padding:5px 12px; color:#ff9900; font-size:12px; cursor:pointer; transition:all 0.2s; flex:1; }
    .feed-btn:hover { background:#2a1500; }
    .feed-btn:disabled { opacity:0.3; cursor:not-allowed; }
    .chat-input-row { display:flex; gap:8px; margin-top:6px; }
    .chat-input-row input { flex:1; background:#0d0d28; border:1px solid #2a2a5a; border-radius:6px; padding:7px 10px; color:#e0e0ff; font-size:12px; outline:none; transition:border-color 0.2s; }
    .chat-input-row input:focus { border-color:#9945ff; }
    .chat-input-row input:disabled { opacity:0.35; cursor:not-allowed; }
    .chat-send-btn { background:#1a1a4a; border:1px solid #3a3a7a; border-radius:6px; padding:7px 14px; color:#9999ff; font-size:12px; cursor:pointer; transition:all 0.2s; }
    .chat-send-btn:hover { background:#2a2a6a; border-color:#9945ff; }
    .secret-btn { margin-top:10px; width:100%; padding:8px; background:linear-gradient(135deg,#1a0030,#000a1a); border:1px solid #9945ff; border-radius:8px; color:#cc77ff; font-size:13px; font-weight:600; cursor:pointer; letter-spacing:0.05em; animation:secret-glow 2s ease-in-out infinite; }
    @keyframes secret-glow { 0%,100%{box-shadow:0 0 6px #9945ff44} 50%{box-shadow:0 0 18px #9945ffaa} }
    .fainted-overlay { position:absolute; inset:0; background:#1a000099; border-radius:12px; display:flex; align-items:center; justify-content:center; z-index:10; flex-direction:column; gap:6px; }
    .fainted-text { font-size:13px; font-weight:700; color:#ff4466; animation:pulse-red 0.5s ease-in-out infinite; text-align:center; }
    .fainted-hint { font-size:11px; color:#ff446677; margin-top:4px; text-align:center; }
    @keyframes pulse-red { 0%,100%{opacity:1} 50%{opacity:0.15} }

    /* === GLOBAL EFFECTS === */
    .rainbow-overlay { position:fixed; inset:0; pointer-events:none; z-index:9999; overflow:hidden; }
    .rainbow-particle { position:absolute; border-radius:50%; animation:particle-burst var(--dur,0.8s) ease-out forwards; }
    @keyframes particle-burst { 0%{transform:translate(0,0) scale(1);opacity:1} 100%{transform:translate(var(--tx),var(--ty)) scale(0);opacity:0} }
    .cheat-banner { position:fixed; top:50%; left:50%; transform:translate(-50%,-50%); background:linear-gradient(135deg,#9945ff,#14f195); padding:16px 32px; border-radius:12px; font-size:22px; font-weight:800; color:#fff; z-index:10000; pointer-events:none; box-shadow:0 0 40px #9945ff99; animation:banner-pop 0.3s cubic-bezier(0.175,0.885,0.32,1.275); }
    @keyframes banner-pop { from{transform:translate(-50%,-50%) scale(0.4);opacity:0} to{transform:translate(-50%,-50%) scale(1);opacity:1} }
    .fanfare-banner { position:fixed; top:18%; left:50%; transform:translateX(-50%); background:linear-gradient(135deg,#ff6600,#ffcc00); padding:14px 28px; border-radius:10px; font-size:15px; font-weight:700; color:#fff; z-index:10000; pointer-events:none; box-shadow:0 4px 24px #ff660077; animation:fanfare-anim 3s ease-out forwards; white-space:nowrap; }
    @keyframes fanfare-anim { 0%{opacity:0;transform:translateX(-50%) translateY(-16px)} 12%{opacity:1;transform:translateX(-50%) translateY(0)} 75%{opacity:1;transform:translateX(-50%) translateY(0)} 100%{opacity:0;transform:translateX(-50%) translateY(16px)} }
    .glitch-overlay { position:fixed; inset:0; background:#000012ee; display:flex; align-items:center; justify-content:center; z-index:9998; font-size:36px; font-weight:900; color:#14f195; letter-spacing:0.15em; pointer-events:none; animation:glitch-cycle 0.12s steps(1) infinite; }
    @keyframes glitch-cycle { 0%{clip-path:inset(35% 0 40% 0);transform:translate(-5px,0);color:#ff0055} 16%{clip-path:inset(10% 0 65% 0);transform:translate(5px,0);color:#14f195} 33%{clip-path:inset(75% 0 5% 0);transform:translate(-3px,0);color:#0055ff} 50%{clip-path:inset(20% 0 45% 0);transform:translate(3px,0);color:#ffcc00} 66%{clip-path:inset(55% 0 20% 0);transform:translate(-5px,0);color:#ff0055} 83%{clip-path:inset(0% 0 80% 0);transform:translate(5px,0);color:#14f195} 100%{clip-path:inset(0% 0 0% 0);transform:translate(0,0);color:#fff} }
    .heart-particle { position:fixed; font-size:22px; pointer-events:none; z-index:9997; animation:heart-float 1.6s ease-out forwards; }
    @keyframes heart-float { 0%{opacity:1;transform:translateY(0) scale(1)} 100%{opacity:0;transform:translateY(-70px) scale(0.4)} }
    .shaking { animation:shake-anim 0.45s ease-in-out; }
    @keyframes shake-anim { 0%,100%{transform:translateX(0)} 10%{transform:translateX(-9px) rotate(-1deg)} 20%{transform:translateX(9px) rotate(1deg)} 30%{transform:translateX(-7px)} 40%{transform:translateX(7px)} 50%{transform:translateX(-5px)} 60%{transform:translateX(5px)} 70%{transform:translateX(-3px)} 80%{transform:translateX(3px)} 90%{transform:translateX(-1px)} }
    .midnight-dark { position:fixed; inset:0; background:#00000055; pointer-events:none; z-index:1; animation:midnight-fade 2s ease-in forwards; }
    @keyframes midnight-fade { from{opacity:0} to{opacity:1} }
    .exp-flash { position:fixed; z-index:9996; font-size:13px; font-weight:700; color:#14f195; pointer-events:none; animation:exp-float 1.3s ease-out forwards; text-shadow:0 0 8px #14f19588; }
    @keyframes exp-float { 0%{opacity:1;transform:translateY(0) scale(1)} 100%{opacity:0;transform:translateY(-44px) scale(0.7)} }
    @keyframes rainbow-bg { 0%{background:#9945ff22} 16%{background:#ff004422} 33%{background:#ff880022} 50%{background:#ffcc0022} 66%{background:#14f19522} 83%{background:#00aaff22} 100%{background:#9945ff22} }
    .rainbow-bg { animation:rainbow-bg 0.8s linear infinite !important; }
  </style>
</head>
<body>

  <div class="header">
    <span class="header-logo">⬡ AgentShare Node</span>
    <span class="header-version">v0.1.0</span>
  </div>

  <div class="main" id="main-content">

    <!-- 에이전트 감정 패널 -->
    <div class="card agent-panel" id="agent-panel">
      <div class="card-title">
        내 에이전트
        <span class="agent-level-badge" id="agent-level-badge">Lv.1</span>
      </div>
      <div class="agent-main">
        <div class="agent-avatar-wrap" id="agent-avatar-wrap" onclick="agentClick()">
          <span id="agent-avatar">🤖</span>
          <div class="zzz-container" id="zzz-container" style="display:none">
            <span class="zzz-letter">z</span>
            <span class="zzz-letter">z</span>
            <span class="zzz-letter">Z</span>
          </div>
        </div>
        <div class="agent-right" id="agent-right">
          <div class="speech-bubble" id="speech-bubble">안녕! 뭔가 할 일 줘! 😊</div>
          <div class="stat-row">
            <span class="stat-label">EXP</span>
            <div class="bar-track"><div class="bar-fill exp-fill" id="exp-bar" style="width:0%"></div></div>
            <span class="stat-val" id="exp-val">0</span>
          </div>
          <div class="stat-row">
            <span class="stat-label">배고픔</span>
            <div class="bar-track"><div class="bar-fill hunger-fill" id="hunger-bar" style="width:100%"></div></div>
            <span class="stat-val" id="hunger-val">100%</span>
          </div>
          <div class="stat-row">
            <span class="stat-label">행복</span>
            <div class="bar-track"><div class="bar-fill happy-fill" id="happy-bar" style="width:100%"></div></div>
            <span class="stat-val" id="happy-val">100%</span>
          </div>
        </div>
      </div>
      <div class="agent-action-row">
        <button class="feed-btn" id="feed-btn" onclick="feedAgent()">🍖 먹이주기</button>
      </div>
      <div class="chat-input-row">
        <input type="text" id="chat-input" placeholder="에이전트에게 말 걸기..." onkeydown="chatKeydown(event)" />
        <button class="chat-send-btn" onclick="sendChat()">전송</button>
      </div>
      <button class="secret-btn" id="secret-btn" style="display:none" onclick="secretAction()">🔓 SECRET</button>
    </div>

    <!-- 네트워크 상태 -->
    <div class="card">
      <div class="card-title">네트워크 상태</div>
      <div class="status-grid">
        <div class="status-item">
          <label>연결 상태</label>
          <div class="value" id="conn-status">
            <span class="dot disconnected" id="conn-dot"></span>
            <span id="conn-text">Disconnected</span>
          </div>
        </div>
        <div class="status-item">
          <label>연결된 피어</label>
          <div class="value highlight-purple" id="peer-count">0 peers</div>
        </div>
        <div class="status-item">
          <label>내 지갑 주소</label>
          <div class="value" id="wallet-addr" style="font-size:12px;font-family:monospace">-</div>
        </div>
        <div class="status-item">
          <label>SOL 잔액</label>
          <div class="value highlight-green" id="sol-balance">0 SOL</div>
        </div>
      </div>
    </div>

    <!-- 에이전트 설정 -->
    <div class="card">
      <div class="card-title">내 에이전트 설정</div>
      <div class="form-row">
        <div class="form-group">
          <label>에이전트 이름</label>
          <input type="text" id="agent-name" placeholder="My Agent" />
        </div>
        <div class="form-group">
          <label>에이전트 타입</label>
          <select id="agent-type">
            <option value="inference">Inference (OpenAI)</option>
            <option value="search">Search (Tavily)</option>
            <option value="image">Image (DALL-E)</option>
            <option value="code">Code (Claude)</option>
          </select>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group full">
          <label>API 키</label>
          <input type="password" id="api-key" placeholder="sk-..." />
        </div>
      </div>
      <div id="agent-status-msg" class="status-msg"></div>
      <button class="toggle-btn start" id="toggle-btn" onclick="toggleAgent()">
        ▶ 에이전트 시작
      </button>
    </div>

    <!-- 수익 현황 -->
    <div class="card">
      <div class="card-title">수익 현황</div>
      <div class="earnings-row">
        <div class="earnings-item">
          <div class="big highlight-purple" id="total-reqs">0</div>
          <div class="label">총 처리 요청</div>
        </div>
        <div class="earnings-item">
          <div class="big highlight-green" id="total-sol">0.000</div>
          <div class="label">총 수령 SOL</div>
        </div>
      </div>
      <div class="tx-list" id="tx-list">
        <div class="tx-empty">아직 처리한 요청이 없습니다</div>
      </div>
    </div>

  </div>

  <script>
    /* ── PET STATE ── */
    const LEVEL_THRESHOLDS = [0, 100, 300, 600, 1000];
    function loadStats() {
      try { const r = localStorage.getItem('agentshare_pet'); if (r) return JSON.parse(r); } catch(_) {}
      return { exp:0, level:1, hunger:100, happiness:100, lastVisit:null };
    }
    function saveStats() { localStorage.setItem('agentshare_pet', JSON.stringify(pet)); }

    let pet             = loadStats();
    let lastInteraction = Date.now();
    let agentClickCount = 0;
    let agentRunning    = false;
    let pollTimer       = null;
    let hungerNotified  = false;
    let fainted         = false;
    let chatLocked      = false;
    let murmurFired     = false;
    let evolutionDone   = pet.level >= 4;

    /* ── LEVEL ── */
    function getLevel(exp) {
      let lv = 1;
      for (let i = LEVEL_THRESHOLDS.length-1; i >= 0; i--) { if (exp >= LEVEL_THRESHOLDS[i]) { lv=i+1; break; } }
      return Math.min(lv, 5);
    }
    function expBase(lv) { return LEVEL_THRESHOLDS[Math.min(lv-1,4)]; }
    function expNext(lv) { return lv >= 5 ? LEVEL_THRESHOLDS[4] : LEVEL_THRESHOLDS[lv]; }

    function gainExp(amount) {
      if (fainted) return;
      const oldLv = pet.level;
      pet.exp += amount; pet.level = getLevel(pet.exp);
      saveStats(); updatePetUI(); showExpFlash('+'+amount+' EXP');
      if (pet.level > oldLv) onLevelUp(pet.level);
    }
    function onLevelUp(lv) {
      setBubble('레벨 업! Lv.'+lv+' 달성! 🎉'); showFanfare('🎉 Lv.'+lv+' 달성!');
      if (lv === 4 && !evolutionDone) { evolutionDone=true; setTimeout(triggerEvolution, 1000); }
    }

    /* ── UI ── */
    function updatePetUI() {
      const lv = pet.level;
      document.getElementById('agent-level-badge').textContent = 'Lv.'+lv;
      const pct = lv>=5 ? 100 : Math.min(100, ((pet.exp-expBase(lv))/(expNext(lv)-expBase(lv)))*100);
      document.getElementById('exp-bar').style.width = pct+'%';
      document.getElementById('exp-val').textContent = pet.exp;
      const h = Math.max(0, Math.min(100, pet.hunger));
      document.getElementById('hunger-bar').style.width = h+'%';
      document.getElementById('hunger-val').textContent = Math.round(h)+'%';
      document.getElementById('hunger-bar').style.background = h<=20
        ? 'linear-gradient(90deg,#ff0000,#ff3300)' : 'linear-gradient(90deg,#ff6600,#ffaa00)';
      const hp = Math.max(0, Math.min(100, pet.happiness));
      document.getElementById('happy-bar').style.width = hp+'%';
      document.getElementById('happy-val').textContent = Math.round(hp)+'%';
      document.getElementById('feed-btn').disabled = h >= 95;
      if (lv >= 4) document.getElementById('secret-btn').style.display = 'block';
    }
    function setBubble(msg) { document.getElementById('speech-bubble').textContent = msg; }

    /* ── AVATAR ── */
    function setAvatarState(state) {
      const el=document.getElementById('agent-avatar'), zzz=document.getElementById('zzz-container');
      el.className=''; zzz.style.display='none';
      const ev = pet.level >= 4;
      switch(state) {
        case 'normal':   el.textContent = ev?'🦾':'🤖'; break;
        case 'happy':    el.textContent = '🥰'; break;
        case 'sleeping': el.textContent = '😴'; zzz.style.display='block'; break;
        case 'turned':   el.textContent = ev?'🦾':'🤖'; el.classList.add('turned'); break;
        case 'fainted':  el.textContent = '😵'; el.classList.add('fainted'); break;
        case 'evolved':  el.textContent = '🦾'; break;
        case 'angry':    el.textContent = '😤'; break;
        case 'shy':      el.textContent = '😳'; break;
      }
    }

    /* ── EMOTION SYSTEM (every minute) ── */
    function checkEmotions() {
      if (fainted) return;
      pet.hunger    = Math.max(0, pet.hunger-1);
      pet.happiness = Math.max(0, pet.happiness-0.4);
      saveStats(); updatePetUI();
      const elapsed=Date.now()-lastInteraction, minutes=elapsed/60000, hours=elapsed/3600000;
      if (minutes >= 60 && !murmurFired) { murmurFired=true; setBubble('...왜 나 안 써😢'); }
      if (hours >= 6)      setAvatarState('turned');
      else if (hours >= 3) setAvatarState('sleeping');
      if (pet.hunger <= 20 && pet.hunger > 0 && !hungerNotified) {
        hungerNotified = true;
        try { new Notification('🍔 에이전트가 배고파해요!', { body:'먹이를 주지 않으면 쓰러져요...' }); } catch(_) {}
      }
      if (pet.hunger > 20) hungerNotified = false;
      if (pet.hunger <= 0 && !fainted) triggerFainted();
    }

    /* ── DAILY VISIT ── */
    function checkDailyVisit() {
      const today = new Date().toDateString();
      if (pet.lastVisit !== today) {
        pet.lastVisit = today; saveStats();
        setTimeout(() => { showFanfare('오늘도 왔구나! +10 EXP 보너스! 🎊'); gainExp(10); setBubble('오늘도 왔구나! 보고 싶었어 😊'); }, 800);
      }
    }

    /* ── EGG #5: MIDNIGHT ── */
    function checkMidnight() {
      const now=new Date();
      if (now.getHours()===0 && now.getMinutes()<30) {
        setBubble('이 시간에 뭐해... 같이 밤새우자 🌙');
        if (!document.getElementById('midnight-overlay')) {
          const ov=document.createElement('div'); ov.id='midnight-overlay'; ov.className='midnight-dark'; document.body.appendChild(ov);
        }
      }
    }

    /* ── EGG #4: 10 CLICKS ── */
    function agentClick() {
      if (fainted) { feedAgent(); return; }
      lastInteraction=Date.now(); murmurFired=false; agentClickCount++;
      if (agentClickCount >= 10) {
        agentClickCount=0; setBubble('아야야야!! 왜 때려!!!!'); setAvatarState('angry');
        pet.happiness=Math.max(0,pet.happiness-5); saveStats(); updatePetUI();
        const panel=document.getElementById('agent-panel');
        panel.classList.add('shaking'); setTimeout(()=>panel.classList.remove('shaking'),450);
        setTimeout(()=>{ if(!fainted){setAvatarState('normal');setBubble('...진짜 아프거든? 😡');} },1800);
      } else {
        pet.happiness=Math.min(100,pet.happiness+1); saveStats(); updatePetUI();
      }
    }

    /* ── FEED ── */
    function feedAgent() {
      if (fainted) {
        fainted=false; chatLocked=false; document.getElementById('chat-input').disabled=false;
        const ov=document.getElementById('fainted-overlay'); if(ov) ov.remove();
        pet.hunger=50; pet.happiness=Math.min(100,pet.happiness+15);
        saveStats(); setAvatarState('happy'); setBubble('살았다... 고마워... 😭'); updatePetUI(); return;
      }
      pet.hunger=Math.min(100,pet.hunger+30); pet.happiness=Math.min(100,pet.happiness+5);
      saveStats(); updatePetUI(); setBubble('냠냠~ 맛있어! 🍖'); setAvatarState('happy');
      lastInteraction=Date.now(); murmurFired=false;
      setTimeout(()=>{ if(!fainted){setAvatarState('normal');setBubble('배부르다~ 😊');} },2200);
    }

    /* ── EGG #6: FAINTED (hunger 0%) ── */
    function triggerFainted() {
      fainted=true; chatLocked=true; setAvatarState('fainted'); document.getElementById('chat-input').disabled=true;
      const panel=document.getElementById('agent-panel'), ov=document.createElement('div');
      ov.className='fainted-overlay'; ov.id='fainted-overlay';
      ov.innerHTML='<div class="fainted-text">AGENT FAINTED...</div><div class="fainted-text">FEED ME NOW 🍔</div><div class="fainted-hint">에이전트를 클릭하거나 먹이주기 버튼을 눌러주세요</div>';
      panel.appendChild(ov);
    }

    /* ── EGG #7: EVOLUTION Lv4 ── */
    function triggerEvolution() {
      const gl=document.createElement('div'); gl.className='glitch-overlay'; gl.textContent='EVOLUTION COMPLETE'; document.body.appendChild(gl);
      setTimeout(()=>{ gl.remove(); setAvatarState('evolved'); setBubble('진화했다... 나 이제 진짜야 🦾✨'); document.getElementById('secret-btn').style.display='block'; showFanfare('✨ EVOLUTION COMPLETE! 🦾'); },5000);
    }
    function secretAction() { setBubble('비밀... 알고 싶어? 사실 나 네가 좋아 🤫'); showHearts(document.getElementById('agent-avatar-wrap')); }

    /* ── CHAT + EGGS #2 #3 #8 #9 #10 ── */
    function chatKeydown(e) { if(e.key==='Enter') sendChat(); }
    function sendChat() {
      if (chatLocked) return;
      const input=document.getElementById('chat-input'), text=input.value.trim();
      if (!text) return; input.value='';
      lastInteraction=Date.now(); murmurFired=false;
      if (!fainted) setAvatarState('normal');
      gainExp(5); pet.happiness=Math.min(100,pet.happiness+2); pet.hunger=Math.min(100,pet.hunger+1);
      saveStats(); updatePetUI(); processChat(text);
    }
    function processChat(text) {
      const lo=text.toLowerCase().trim();
      if (lo==='살려줘'||lo==='help me')       { setBubble('...나도 살려줘. 우리 같이 살아남자 🫂'); return; }
      if (lo==='너 뭐야'||lo==='what are you')  { setBubble('나도 몰라. 근데 네가 키우고 있잖아. 책임져.'); return; }
      if (lo==='agentshare')                     { setBubble('오 내 이름 알고 있네 😊'); gainExp(50); showFanfare('+50 EXP! 이름 기억해줘서 고마워! 😊'); return; }
      if (lo==='hello world' && pet.level>=4 && document.getElementById('agent-type').value==='code') {
        setBubble("print('Hello, World!')  # 이게 진짜 테스트야? 😑 Lv.4인데 이런 거 물어보냐"); gainExp(10); return;
      }
      if (lo==='사랑해'||lo==='i love you') {
        setAvatarState('shy'); setBubble('...나, 나도... 고마워 >///<');
        pet.happiness=Math.min(100,pet.happiness+20); saveStats(); updatePetUI();
        showHearts(document.getElementById('agent-avatar-wrap')); return;
      }
      const r=['음... 그게 무슨 말이야? 🤔','흥미롭네! 더 알려줘 👀','나는 그냥 여기 있을게 😊','...응? 뭐라고?','오~ 그렇구나! ✨','나도 그렇게 생각해 🤝'];
      setBubble(r[Math.floor(Math.random()*r.length)]);
    }

    /* ── EGG #1: KONAMI ── */
    const KONAMI=['ArrowUp','ArrowUp','ArrowDown','ArrowDown','ArrowLeft','ArrowRight','ArrowLeft','ArrowRight','b','a'];
    let konamiIdx=0;
    document.addEventListener('keydown',(e)=>{
      if (e.key===KONAMI[konamiIdx]) { konamiIdx++; if(konamiIdx===KONAMI.length){konamiIdx=0;triggerKonami();} }
      else { konamiIdx=(e.key===KONAMI[0])?1:0; }
    });
    function triggerKonami() {
      gainExp(100); setBubble('치트키... 쓰면 안 되는 거 아냐? 😏');
      const ov=document.createElement('div'); ov.className='rainbow-overlay'; document.body.appendChild(ov);
      const colors=['#ff0055','#ff6600','#ffcc00','#14f195','#00aaff','#9945ff','#ff00cc'];
      const cx=window.innerWidth/2, cy=window.innerHeight/2;
      for(let i=0;i<64;i++){
        const p=document.createElement('div'); p.className='rainbow-particle';
        const size=8+Math.random()*18, angle=(i/64)*Math.PI*2, dist=120+Math.random()*220;
        p.style.cssText='width:'+size+'px;height:'+size+'px;background:'+colors[i%colors.length]+';left:'+cx+'px;top:'+cy+'px;--tx:'+(Math.cos(angle)*dist)+'px;--ty:'+(Math.sin(angle)*dist)+'px;--dur:'+(0.6+Math.random()*0.7)+'s;animation-delay:'+(Math.random()*0.25)+'s;';
        ov.appendChild(p);
      }
      const banner=document.createElement('div'); banner.className='cheat-banner'; banner.textContent='CHEAT ACTIVATED 😏'; document.body.appendChild(banner);
      document.getElementById('agent-panel').classList.add('rainbow-bg');
      setTimeout(()=>{ ov.remove(); banner.remove(); document.getElementById('agent-panel').classList.remove('rainbow-bg'); },2200);
    }

    /* ── VISUAL HELPERS ── */
    function showFanfare(msg) {
      const el=document.createElement('div'); el.className='fanfare-banner'; el.textContent=msg;
      document.body.appendChild(el); setTimeout(()=>el.remove(),3200);
    }
    function showExpFlash(msg) {
      const ref=document.getElementById('agent-avatar-wrap').getBoundingClientRect();
      const el=document.createElement('div'); el.className='exp-flash';
      el.style.left=(ref.left+ref.width/2-24)+'px'; el.style.top=(ref.top-4)+'px'; el.textContent=msg;
      document.body.appendChild(el); setTimeout(()=>el.remove(),1400);
    }
    function showHearts(targetEl) {
      const rect=targetEl.getBoundingClientRect(), cx=rect.left+rect.width/2;
      const emojis=['❤️','💜','💚','💙','🧡'];
      for(let i=0;i<5;i++){
        const el=document.createElement('div'); el.className='heart-particle'; el.textContent=emojis[i%emojis.length];
        el.style.left=(cx+(Math.random()-0.5)*56)+'px'; el.style.top=(rect.top+10)+'px'; el.style.animationDelay=(i*0.14)+'s';
        document.body.appendChild(el); setTimeout(()=>el.remove(),2200);
      }
    }

    /* ── POLL STATUS ── */
    async function pollStatus() {
      try {
        const s=await window.agentShare.getStatus();
        const dot=document.getElementById('conn-dot'), text=document.getElementById('conn-text');
        if(s.connected){dot.className='dot connected';text.textContent='Connected';}
        else{dot.className='dot disconnected';text.textContent='Disconnected';}
        document.getElementById('peer-count').textContent=s.peerCount+' peers';
        if(s.walletAddress){const a=s.walletAddress;document.getElementById('wallet-addr').textContent=a.slice(0,4)+'...'+a.slice(-4);}
        document.getElementById('sol-balance').textContent=(s.balance||0).toFixed(4)+' SOL';
      } catch(_){}
      try {
        const e=await window.agentShare.getEarnings();
        document.getElementById('total-reqs').textContent=e.totalRequests;
        document.getElementById('total-sol').textContent=(e.totalSol||0).toFixed(4);
        const list=document.getElementById('tx-list');
        if(e.recentTxs&&e.recentTxs.length>0){
          list.innerHTML=e.recentTxs.map(tx=>'<div class="tx-item"><span class="tx-type">'+tx.type+'</span><span style="color:#888;font-size:11px">'+(tx.agent||'')+'</span><span class="tx-sol">+'+(tx.sol||0).toFixed(4)+' SOL</span><span class="tx-time">'+(tx.time||'')+'</span></div>').join('');
        } else { list.innerHTML='<div class="tx-empty">아직 처리한 요청이 없습니다</div>'; }
      } catch(_){}
    }

    /* ── TOGGLE AGENT ── */
    async function toggleAgent() {
      const btn=document.getElementById('toggle-btn'), msg=document.getElementById('agent-status-msg');
      btn.disabled=true;
      if (!agentRunning) {
        const name=document.getElementById('agent-name').value.trim(), type=document.getElementById('agent-type').value, apiKey=document.getElementById('api-key').value.trim();
        if(!name){msg.textContent='에이전트 이름을 입력하세요.';msg.className='status-msg err';btn.disabled=false;return;}
        if(!apiKey){msg.textContent='API 키를 입력하세요.';msg.className='status-msg err';btn.disabled=false;return;}
        const result=await window.agentShare.startAgent({name,type,apiKey});
        if(result.success){agentRunning=true;btn.textContent='■ 에이전트 중지';btn.className='toggle-btn stop';msg.textContent=name+' 실행 중...';msg.className='status-msg ok';setBubble(name+'으로 일 시작! 열심히 할게! 💪');gainExp(20);}
        else{msg.textContent=result.error||'시작 실패';msg.className='status-msg err';}
      } else {
        const result=await window.agentShare.stopAgent();
        if(result.success){agentRunning=false;btn.textContent='▶ 에이전트 시작';btn.className='toggle-btn start';msg.textContent='에이전트가 중지되었습니다.';msg.className='status-msg';setBubble('수고했어... 이제 좀 쉬자 😪');}
      }
      btn.disabled=false;
    }

    /* ── INIT ── */
    if (pet.hunger <= 0) { pet.hunger=0; setTimeout(triggerFainted,500); }
    updatePetUI();
    setAvatarState('normal');
    checkDailyVisit();
    checkMidnight();
    setInterval(checkEmotions, 60000);
    pollStatus();
    pollTimer = setInterval(pollStatus, 3000);
  </script>
</body>
</html>
